{
  "name": "mikha",
  "version": "1.0.0",
  "description": "Un agente de IA personal local",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env src/index.ts",
    "dev:uni": "tsx --env-file=.env.uni src/index_uni.ts",
    "dev:const": "tsx --env-file=.env.const src/index_const.ts",
    "dev:inmo": "tsx --env-file=.env.inmo src/index_inmo.ts",
    "dev:mark": "tsx --env-file=.env.mark src/index_mark.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:uni": "node dist/index_uni.js",
    "start:const": "node dist/index_const.js",
    "start:inmo": "node dist/index_inmo.js",
    "start:mark": "node dist/index_mark.js"
  },
  "dependencies": {
    "@grammyjs/files": "^1.2.0",
    "better-sqlite3": "^11.5.0",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "googleapis": "^171.4.0",
    "grammy": "^1.32.0",
    "gtts": "^0.2.1",
    "nodemailer": "^8.0.4",
    "pdf-parse-new": "^2.0.0",
    "turndown": "^7.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.8.6",
    "@types/nodemailer": "^8.0.0",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
